{
  "identifier": "default",
  "description": "Default capability for the Shazam Dashboard",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://127.0.0.1:**" },
        { "url": "http://localhost:**" }
      ]
    },
    "websocket:default"
  ]
}
